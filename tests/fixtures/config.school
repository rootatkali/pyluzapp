<school-configuration name="Titan24" sync-server="gitlab.com">
    <elements>
        <groups>
            <group size="11" name="ונוס"/>
            <group size="0" name="קבוצות אם"/>
            <group size="100" name="סגל"/>
        </groups>

        <tracks>
			<track name="ונוס"/>
			<track name="סגל" />
        </tracks>

        <classes>
            <class name="ונוס" seats="1000" workstations="100" />
            <class name="עצמאי" seats="1000" workstations="100" />
        </classes>
    </elements>

    <defaultclass name="Teams"/>
    <segel>
        <group name="סגל מוביל"> 
            <person name="שירה ארוב" sex="female" />
        </group>

        <group name="מפקדי ונוס">
            <person name="לירון לוי" sex="female" />
            <person name="אורין אלביליה" sex="female" />
            <person name="עלמה בירן" sex="female" />
            <person name="מיקה ליבוביץ'" sex="female" />
            <person name="מעיין זילברמן" sex="female" />
            <person name="יהונתן ויינברג" sex="male" />
            <person name="שובל אלקלעי" sex="male" />
        </group>

        <group name="מפקדי מאגמה">
            <person name="עידו גנלין" sex="male" />
            <person name="אדם גאר" sex="male" />
            <person name="שירה שמשון" sex="female" />
            <person name="גומא אביגדור" sex="male" />
        </group>

        <group name="מפקדי טרויה">
            <person name="אלון הולשטיין" sex="male" />
            <person name="לירי קרת" sex="female" />
            <person name="אמיר מנדלמילק" sex="male" />
            <person name="טל זיני" sex="female" />
            <person name="איתי כהן" sex="male" />
            <person name="ליאור גולדברג" sex="male" />
            <person name="מאור גורדון" sex="male" />
            <person name="אורי שמחוני" sex="male" />
            <person name="שני סולומון" sex="female" />
        </group>

        <group name="מפקדי ארטמיס">
            <person name="אור אנג'ל" sex="female" />
            <person name="אופק שושן" sex="male" />
            <person name="רותם מוזס" sex="male" />
            <person name="אור מוהבטי" sex="male" />
            <person name="אמיתי שחר" sex="male" />
            <person name="מאיה גבע" sex="female" />
            <person name="נטע ויסברד" sex="female" />
            <person name="אביאל קהרמני" sex="male" />
            <person name="אלעד אלקבץ" sex="male" />
            <person name="אורי זהבי" sex="male" />
            <person name="שליו שגן" sex="male" />
            <person name="זיו פרויד" sex="male" />
            <person name="עתי אמבוס" sex="male" />
        </group>

        <group name="מיוחדים">
            <person name="איש חוץ" sex="male" />
            <person name="פיקטיבי" sex="male" />
            <person name="קריטי" sex="male" />
            <person name="Hidden" sex="male" />
            <person name="ללא ביזור" sex="male" />
        </group>
    </segel>

